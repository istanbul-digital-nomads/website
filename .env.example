# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service-role key. Only used server-side by scripts/ingest-corpus.ts to
# write corpus_chunks and by the relocation agent route to write
# relocation_plans. Never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (contact form emails)
RESEND_API_KEY=re_your_api_key_here

# Relocation decision agent
# Anthropic Claude (generation) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Voyage AI (embeddings) - https://www.voyageai.com
VOYAGE_API_KEY=pa-your_key_here

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=istanbulnomads.com
# Google Analytics 4 - get from https://analytics.google.com (Admin → Data Streams → Web → Measurement ID)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel (auto-populated on Vercel deployments)
VERCEL_URL=
VERCEL_ENV=

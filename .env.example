# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service-role key. Only used server-side by the relocation agent route to
# write relocation_plans for authenticated members. Never exposed to the
# browser. Optional - if unset, plans are not persisted but the agent still
# returns results
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (contact form emails)
RESEND_API_KEY=re_your_api_key_here

# Analytics (optional)
# Google Tag Manager - get from https://tagmanager.google.com (container ID).
# The container loads the GA4 Google tag and forwards funnel events, so the
# app no longer needs a separate GA measurement ID.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry error tracking (optional, server-side only).
# Without SENTRY_DSN the SDK no-ops, so the app runs fine unset. Set the DSN
# in Vercel to start capturing server/SSR/route-handler errors. ORG/PROJECT/
# AUTH_TOKEN are only needed to upload source maps at build time (CI).
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel (auto-populated on Vercel deployments)
VERCEL_URL=
VERCEL_ENV=
